<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.controllers.StackController">
    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="600.0" prefWidth="800.0">
        <children>
            <Label fx:id="lbl_Title" layoutX="9.0" layoutY="39.0" prefHeight="93.0" prefWidth="782.0" text="EXAMPLE" textAlignment="CENTER">
                <font>
                    <Font size="64.0" />
                </font>
            </Label>
            <TextField fx:id="txt_Gold" layoutX="168.0" layoutY="234.0" prefHeight="25.0" prefWidth="71.0" />
            <TextField fx:id="txt_Silver" layoutX="270.0" layoutY="234.0" prefHeight="25.0" prefWidth="71.0" />
            <TextField fx:id="txt_Copper" layoutX="365.0" layoutY="234.0" prefHeight="25.0" prefWidth="71.0" />
            <Label fx:id="lbl_Sub1" layoutX="131.0" layoutY="147.0" prefHeight="35.0" prefWidth="539.0" text="EXAMPLE" textAlignment="CENTER">
                <font>
                    <Font size="24.0" />
                </font>
            </Label>
            <Button fx:id="btn_Mul" layoutX="290.0" layoutY="313.0" mnemonicParsing="false" onAction="#handleMore" text="MULT" />
            <Button fx:id="btn_Result" layoutX="357.0" layoutY="313.0" mnemonicParsing="false" onAction="#showResult" text="RESULT">
            <cursor>
               <Cursor fx:constant="OPEN_HAND" />
            </cursor></Button>
            <Line endX="-13.0" endY="30.0" layoutX="362.0" layoutY="313.0" startX="-13.0" startY="-6.0" />
            <Label fx:id="lbl_Info" layoutX="215.0" layoutY="370.0" prefHeight="17.0" prefWidth="359.0" text="Label" textAlignment="CENTER" textFill="#7c7c7c" />
         <Label fx:id="lbl_Error" layoutX="168.0" layoutY="271.0" prefHeight="35.0" prefWidth="438.0" text="ERROR" textAlignment="CENTER" textFill="RED" visible="false">
            <font>
               <Font size="18.0" />
            </font>
         </Label>
         <Button fx:id="btn_Reset" layoutX="433.0" layoutY="313.0" mnemonicParsing="false" onAction="#reset" text="RESET" />
         <Line endX="-13.0" endY="30.0" layoutX="434.0" layoutY="313.0" startX="-13.0" startY="-6.0" />
         <Label layoutX="457.0" layoutY="238.0" text="X" />
         <TextField fx:id="txt_value" layoutX="481.0" layoutY="234.0" prefHeight="25.0" prefWidth="71.0" />
         <Label fx:id="added" layoutX="365.0" layoutY="280.0" text="ADDED" />
         <HBox alignment="CENTER" layoutX="100.0" layoutY="415.0" prefHeight="100.0" prefWidth="627.0" spacing="30.0">
            <children>
               <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="5.0">
                  <children>
                        <Label fx:id="lbl_Value" alignment="CENTER_RIGHT" prefHeight="40.0" prefWidth="145.0" text="Label" textAlignment="RIGHT">
                            <font>
                                <Font size="28.0" />
                            </font>
                        </Label>
                     <Label fx:id="stack" text="Stacks" />
                  </children>
               </HBox>
               <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="5.0">
                  <children>
                        <Label fx:id="lbl_Decimal" alignment="CENTER_RIGHT" prefHeight="35.0" prefWidth="92.0" text="Label" textAlignment="RIGHT">
                            <font>
                                <Font size="28.0" />
                            </font>
                        </Label>
                     <Label fx:id="unit" prefHeight="17.0" prefWidth="34.0" text="Units" />
                  </children>
               </HBox>
            </children>
         </HBox>
        </children>
    </AnchorPane>
    </VBox>
